    },
    "big_dot": {
      "interval_sec": 0.7,
      "frames": ["∙∙∙", "●∙∙", "∙●∙", "∙∙●"]
    },
    "earth": {
      "interval_sec": 0.45,
      "frames": ["🌍", "🌎", "🌏"]
    },
    "clock": {
      "interval_sec": 0.2,
      "frames": ["🕛", "🕐", "🕑", "🕒", "🕓", "🕔", "🕕", "🕖", "🕗", "🕘", "🕙", "🕚"]
