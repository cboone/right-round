      "frames": ["😐", "😐", "😐", "😐", "😐", "😐", "😐", "😐", "😐", "😑"]
    },
    "sick": {
      "interval_sec": 0.9,
      "frames": ["🤢", "🤢", "🤮"]
    },
    "monkey": {
