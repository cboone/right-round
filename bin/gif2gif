#!/usr/bin/env bash
#
# gif2gif - Convert an animated GIF into an ASCII art animated GIF
#
# Dependencies: ffmpeg, ffprobe, chafa, aha, Google Chrome, imagemagick, gifsicle
#
# Usage: gif2gif input.gif [output.gif] [WxH]
#
set -euo pipefail

INPUT="${1:?Usage: gif2gif input.gif [output.gif] [WxH]}"
OUTPUT="${2:-ascii_output.gif}"
SIZE="${3:-80}"

CHAFA_SIZE="$SIZE"
COLS="${SIZE%%x*}"
FONT_SIZE=20

# Verify dependencies
for cmd in ffmpeg ffprobe chafa aha gifsicle; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: '$cmd' is not installed." >&2
    exit 1
  fi
done

# Find Google Chrome
CHROME="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
if [[ ! -x "$CHROME" ]]; then
  echo "Error: Google Chrome is not installed at $CHROME" >&2
  exit 1
fi

# ImageMagick 7 uses 'magick', older versions use 'convert'
if command -v magick &>/dev/null; then
  MAGICK="magick"
elif command -v convert &>/dev/null; then
  MAGICK="convert"
else
  echo "Error: ImageMagick is not installed (need 'magick' or 'convert')." >&2
  exit 1
fi

WORKDIR=$(mktemp -d)
trap 'rm -rf "$WORKDIR"' EXIT

echo "Working in $WORKDIR"

# 1. Extract frame delay (centiseconds) from the source GIF
#    GIFs store delay per frame; grab the first one as a baseline.
DELAY=$(ffprobe -v error -select_streams v:0 \
  -show_entries stream=r_frame_rate \
  -of csv=p=0 "$INPUT" | awk -F'/' '{
        if ($2 > 0) printf "%.0f", 100 / ($1 / $2);
        else printf "10";
    }')
echo "Frame delay: ${DELAY} centiseconds"

# 2. Extract frames as individual PNGs
echo "Extracting frames..."
ffmpeg -v warning -i "$INPUT" -fps_mode vfr "$WORKDIR/frame_%04d.png"

FRAME_COUNT=$(ls "$WORKDIR"/frame_*.png 2>/dev/null | wc -l)
echo "Extracted $FRAME_COUNT frames"

if [[ "$FRAME_COUNT" -eq 0 ]]; then
  echo "Error: No frames extracted from $INPUT" >&2
  exit 1
fi

# 3. Convert each frame: image -> ANSI art -> HTML -> PNG
echo "Converting frames to ASCII art..."
n=0
for frame in "$WORKDIR"/frame_*.png; do
  base=$(basename "$frame" .png)
  html_file="$WORKDIR/${base}.html"
  ascii_png="$WORKDIR/${base}_ascii.png"

  # Build HTML: header, then chafa piped through aha, then footer
  {
    printf '%s' '<!DOCTYPE html>
<html>
<head><style>
* { margin: 0; padding: 0; }
body { background: #010101; }
pre {
  font-family: '"'"'MonaspaceArgon-Regular'"'"', '"'"'Monaspace Argon NF'"'"', monospace;
  font-size: '"${FONT_SIZE}"'px;
  line-height: 1.2;
  color: #ccc;
  background: #000;
  width: '"${COLS}"'ch;
  display: inline-block;
}
</style></head>
<body><pre>'

    chafa \
      --color-extractor median \
      --color-space=din99d \
      --colors 256 \
      --fill braille \
      --format=symbols \
      --optimize 0 \
      --polite on \
      --size="${CHAFA_SIZE}" \
      --symbols ascii \
      --work 9 \
      "$frame" | aha -n

    printf '%s' '</pre></body></html>'
  } > "$html_file"

  # Render HTML to PNG via headless Chrome, then trim the chroma body color.
  # The <pre> has its own #000 background at a fixed width (COLSch), so -trim
  # removes only the #010101 body surround, preserving the full pre rectangle.
  "$CHROME" --headless=new --disable-gpu --no-sandbox \
    --screenshot="$ascii_png" --window-size=2000,2000 \
    "file://$html_file" 2>/dev/null
  "$MAGICK" "$ascii_png" -trim +repage "$ascii_png"

  n=$((n + 1))
  printf "\r  Frame %d / %d" "$n" "$FRAME_COUNT"
done
echo ""

# 4. Reassemble into an animated GIF
echo "Assembling animated GIF..."
"$MAGICK" \
  -delay "$DELAY" \
  -loop 0 \
  "$WORKDIR"/frame_*_ascii.png \
  "$OUTPUT"

# 5. Optimize
RAW_SIZE=$(du -h "$OUTPUT" | cut -f1)
echo "Optimizing with gifsicle..."
gifsicle -O3 --batch "$OUTPUT"

echo "Done: $OUTPUT (${RAW_SIZE} -> $(du -h "$OUTPUT" | cut -f1))"
